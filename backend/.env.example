# Database (Supabase connection string)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# JWT
JWT_SECRET=generate-a-random-64-char-string-here
JWT_REFRESH_SECRET=generate-another-random-64-char-string-here

# LINE (สร้างที่ https://developers.line.biz)
LINE_CHANNEL_ID=xxxx
LINE_CHANNEL_SECRET=xxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxx

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=xxxx

# PromptPay (เบอร์โทรหรือเลขบัตรประชาชน)
PROMPTPAY_ID=0812345678

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx

# CORS
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app","https://liff.line.me"]

# Debug
DEBUG=true
